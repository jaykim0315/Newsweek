---
import ArticleCard from './ArticleCard.astro';

interface Props {
  title: string;
  articles: any[];
  cols: 2 | 3 | 4;
}

const { title, articles, cols } = Astro.props;
---

<section class="my-8">
  <!-- 섹션 헤더 -->
  <h2 class="font-serif-kr font-black text-[1.75rem] leading-none text-ink mb-1.5">{title}</h2>
  <div class="h-[2px] bg-ink mb-0"></div>

  {articles && articles.length > 0 ? (
    <div class="card-grid" data-cols={String(cols)}>
      {articles.map((article) => (
        <div class="card-item">
          <ArticleCard article={article} />
        </div>
      ))}
    </div>
  ) : (
    <p class="font-sans-kr font-light text-sm text-ink/30 py-8 text-center">
      이번 호 해당 섹션 기사 없음
    </p>
  )}
</section>

<style>
  /* ── 기본: 1열 ──────────────────────────── */
  .card-grid {
    display: grid;
    grid-template-columns: 1fr;
  }

  .card-item {
    padding: 1rem 1.25rem;
    border-top: 1px solid #1a1a1a;
  }

  /* ── sm (640px+): 2열 ───────────────────── */
  @media (min-width: 640px) {
    .card-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    /* 각 행의 첫 번째 항목(홀수번째): 우측 테두리 */
    .card-item:nth-child(odd) {
      border-right: 1px solid #1a1a1a;
    }

    /* 첫 번째 행(1~2번 항목): 상단 테두리 제거 */
    .card-item:nth-child(-n+2) {
      border-top: none;
    }
  }

  /* ── lg (1024px+): 3열 또는 4열 ──────────── */
  @media (min-width: 1024px) {
    /* 2열 그리드 (data-cols="2"): sm 그대로 유지 */
    .card-grid[data-cols="2"] {
      grid-template-columns: repeat(2, 1fr);
    }

    /* 3열 그리드 */
    .card-grid[data-cols="3"] {
      grid-template-columns: repeat(3, 1fr);
    }

    .card-grid[data-cols="3"] .card-item:nth-child(odd) {
      border-right: none; /* sm 스타일 초기화 */
    }
    .card-grid[data-cols="3"] .card-item:not(:nth-child(3n)) {
      border-right: 1px solid #1a1a1a;
    }
    .card-grid[data-cols="3"] .card-item:nth-child(-n+2) {
      border-top: 1px solid #1a1a1a; /* sm 초기화 복원 */
    }
    .card-grid[data-cols="3"] .card-item:nth-child(-n+3) {
      border-top: none;
    }

    /* 4열 그리드 */
    .card-grid[data-cols="4"] {
      grid-template-columns: repeat(4, 1fr);
    }

    .card-grid[data-cols="4"] .card-item:nth-child(odd) {
      border-right: none; /* sm 스타일 초기화 */
    }
    .card-grid[data-cols="4"] .card-item:not(:nth-child(4n)) {
      border-right: 1px solid #1a1a1a;
    }
    .card-grid[data-cols="4"] .card-item:nth-child(-n+2) {
      border-top: 1px solid #1a1a1a; /* sm 초기화 복원 */
    }
    .card-grid[data-cols="4"] .card-item:nth-child(-n+4) {
      border-top: none;
    }
  }
</style>
