---
interface Article {
  title: string;
  headline: string;
  url: string;
  source_name: string;
  category: string;
  published: string;
  summary: string;
  has_lead_image: boolean;
  image_url?: string | null;
  image_width_hint?: number;
}

interface Props {
  article: Article;
  first?: boolean;
}

const { article, first = false } = Astro.props;

const LABELS: Record<string, string> = {
  marketing: '마케팅',
  economy: '경제',
  local: '지역',
};

function fmtDate(iso: string): string {
  const d = new Date(iso);
  return `${d.getMonth() + 1}월 ${d.getDate()}일`;
}

const firstLine = article.summary.split('\n')[0] ?? '';
const hasImage = Boolean(article.image_url) && (article.image_width_hint ?? 0) >= 400;
---

<article class:list={["py-4", !first && "border-t border-ink"]}>
  <!-- 대표 이미지 4:3 (있을 때만) -->
  {hasImage && (
    <div
      class="overflow-hidden mb-2 img-container-side"
      style="border: 1px solid #1a1a1a;"
    >
      <img
        src={article.image_url!}
        alt={article.headline}
        class="img-fill"
        loading="lazy"
        onerror="this.closest('.img-container-side').style.display='none'"
      />
    </div>
  )}

  <!-- 카테고리 라벨 -->
  <div class="font-sans-kr text-[0.6rem] tracking-[0.15em] uppercase text-wine mb-1.5">
    {LABELS[article.category] ?? article.category}
  </div>

  <!-- 헤드라인 -->
  <h3 class="font-serif-kr font-bold text-[1rem] leading-snug text-ink mb-2">
    {article.headline}
  </h3>

  <!-- 요약 첫 줄 -->
  <p class="font-serif-kr font-normal text-[0.8rem] leading-relaxed text-ink/80 line-clamp-3 mb-2">
    {firstLine}
  </p>

  <!-- 푸터 -->
  <div class="flex flex-wrap items-center gap-x-1.5">
    <span class="font-sans-kr font-light text-[0.6rem] text-ink/50">{article.source_name}</span>
    <span class="text-ink/30 text-[0.6rem]">·</span>
    <span class="font-sans-kr font-light text-[0.6rem] text-ink/50">{fmtDate(article.published)}</span>
    <span class="text-ink/30 text-[0.6rem]">·</span>
    <a
      href={article.url}
      target="_blank"
      rel="noopener noreferrer"
      class="font-sans-kr font-normal text-[0.6rem] text-wine hover:underline underline-offset-2"
    >
      원문 →
    </a>
  </div>
</article>

<style>
  .img-container-side {
    aspect-ratio: 4 / 3;
    position: relative;
  }
  .img-fill {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }
</style>
